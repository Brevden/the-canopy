---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ═══════════════════════════════════════════════════════════ NAV -->
  <nav class="fixed top-0 inset-x-0 z-50 bg-cream/85 backdrop-blur-md border-b border-forest-100/60">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-forest-600 group-hover:text-forest-500 transition-colors">
          <path d="M12 3L6 10h12L12 3z"/>
          <path d="M12 7L4 15h16L12 7z"/>
          <rect x="10" y="15" width="4" height="5" rx="0.5"/>
        </svg>
        <span class="font-display font-semibold text-forest-900 text-lg tracking-tight">Canopy</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-stone-500">
        <a href="#why" class="hover:text-forest-700 transition-colors">Why</a>
        <a href="#what" class="hover:text-forest-700 transition-colors">What it is</a>
        <a href="#how-it-works" class="hover:text-forest-700 transition-colors">How it works</a>
        <a href="https://github.com/Brevden" class="hover:text-forest-700 transition-colors">GitHub</a>
        <a href="https://mastodon.social/@the_canopy" class="inline-flex items-center gap-1.5 bg-forest-900 text-cream px-4 py-1.5 rounded-full hover:bg-forest-700 transition-colors">
          Follow
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- ═══════════════════════════════════════════════════════ HERO -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
      <div class="absolute inset-0 pointer-events-none select-none">
        <svg class="absolute top-0 right-0 w-[700px] h-[700px] opacity-[0.055] translate-x-1/4 -translate-y-1/4" viewBox="0 0 600 600" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="280" cy="260" r="180" fill="#2d6b52"/>
          <circle cx="160" cy="300" r="140" fill="#19372c"/>
          <circle cx="400" cy="220" r="160" fill="#3c8769"/>
          <circle cx="220" cy="170" r="110" fill="#2d6b52"/>
          <circle cx="380" cy="330" r="130" fill="#19372c"/>
          <circle cx="100" cy="380" r="90" fill="#3c8769"/>
          <circle cx="460" cy="380" r="100" fill="#2d6b52"/>
          <circle cx="310" cy="420" r="70" fill="#19372c"/>
        </svg>
        <svg class="absolute bottom-0 left-0 w-[500px] h-[500px] opacity-[0.04] -translate-x-1/3 translate-y-1/4" viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="250" cy="220" r="160" fill="#2d6b52"/>
          <circle cx="130" cy="260" r="120" fill="#19372c"/>
          <circle cx="360" cy="200" r="140" fill="#3c8769"/>
          <circle cx="200" cy="150" r="100" fill="#2d6b52"/>
          <circle cx="350" cy="310" r="110" fill="#19372c"/>
        </svg>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 bg-forest-100/70 text-forest-700 text-xs font-medium tracking-wide uppercase px-4 py-2 rounded-full mb-8 border border-forest-200/50">
          <span class="w-1.5 h-1.5 rounded-full bg-forest-500 inline-block"></span>
          Open source · Self-hosted · Community run
        </div>

        <h1 class="font-display text-5xl md:text-7xl font-bold text-forest-900 leading-[1.08] tracking-tight">
          Does the internet feel<br />
          <span class="text-forest-600 italic">a bit weird right now?</span>
        </h1>

        <p class="mt-8 text-xl md:text-2xl text-stone-500 max-w-xl mx-auto leading-relaxed font-display italic">
          You're not imagining it.
        </p>

        <div class="mt-10">
          <a href="#why" class="inline-flex items-center gap-2 text-forest-700 font-medium hover:text-forest-500 transition-colors">
            Read on
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════ WHY -->
    <section id="why" class="bg-forest-950 py-28 px-6">
      <div class="max-w-3xl mx-auto space-y-20">

        <!-- Act 1: The feeling -->
        <div class="space-y-7 font-display text-[1.1rem] leading-[1.85] text-forest-300/75">
          <p>
            Most people feel it. A vague unease they can't quite name. You open your phone to check
            one thing and forty minutes have gone. You see an ad for something you only mentioned in
            passing. You scroll through content you didn't ask for and feel vaguely worse afterwards.
            You share a photo with friends and it ends up somewhere you didn't quite intend.
          </p>
          <p>
            Nothing dramatic. Just a persistent, low-level feeling that something's a bit off.
            That the internet — which was supposed to be useful, connecting, freeing — has become
            something you do to yourself rather than something you use.
          </p>
        </div>

        <!-- Act 2: The explanation -->
        <div class="space-y-7 font-display text-[1.1rem] leading-[1.85] text-forest-200/85">
          <p>
            The platforms you use every day are built by some of the smartest
            engineers in the world, with one goal: keep you there as long as possible. Every scroll,
            every like, every moment of hesitation is a data point. That data gets fed back into a
            system that learns, adjusts, and gets better at keeping your attention.
          </p>
          <p>
            Your attention is worth money and the longer you stay, the more
            they learn, the more precisely they can target you, and the more they can charge advertisers
            for access to you.
          </p>
          <p class="text-cream font-semibold">
            You're not using the internet. The internet is using you.
          </p>
        </div>

        <!-- Act 3: What it means -->
        <div class="space-y-7 font-display text-[1.1rem] leading-[1.85] text-forest-100/90">
          <p>
            Here's what that looks like in practice. When you upload a photo to share with friends,
            you hand it to a corporation that owns the right to use it however they see fit, and will
            use it to serve you more targeted content. When you message someone you love, a company
            logs it. When you discover an album you adore, an algorithm decides what you hear next —
            not because it has taste, but because it has a model of what keeps you subscribed.
          </p>
          <p>
            The internet — the actual internet, the open network built on the idea that people should
            be able to connect freely — has been replaced by four or five companies that sit between
            you and everyone else. They're not the internet. They built a fence around part of it,
            called it the internet, and charged you your attention and your data to get in.
          </p>
          <p>
            And they did it gradually enough that nobody noticed until it was done.
          </p>
        </div>

        <!-- Act 4: The fury -->
        <div class="space-y-8">
          <div class="space-y-3 font-display text-cream text-xl md:text-2xl leading-relaxed">
            <p>What you watch late at night.</p>
            <p>Who you talk to. What you argue about.</p>
            <p>Where you go. </p>
            <p>What music makes you feel something.</p>
            <p>What you're worried about. What you believe.</p>
          </div>

          <div class="pt-4">
            <p class="font-display font-bold text-cream text-3xl md:text-5xl leading-tight">
              None of that is their business.
            </p>
            <p class="font-display italic text-forest-400 text-2xl md:text-3xl leading-tight mt-3">
              None of it. They didn't build the internet.<br />They just built a fence around part of it.
            </p>
          </div>
        </div>

        <!-- Act 5: The turn -->
        <div class="pt-6 border-t border-forest-800 space-y-7 font-display text-[1.1rem] leading-[1.85]">
          <p class="text-forest-300/80">
            The good news — and there is good news — is that the actual internet still exists.
            The technology that lets two computers talk to each other directly, without a company
            in the middle, still works exactly as it always did. The pipes are still there.
          </p>
          <p class="text-forest-200/90">
            What's been missing is software that makes it easy. Software that lets ordinary people
            own their own corner of the internet, connect directly with the people they trust, and
            share what they love without asking anyone's permission.
          </p>
          <p class="text-cream font-semibold text-xl">
            That's what we built.<br />Let's take it back.
          </p>
        </div>

      </div>
    </section>

    <!-- ════════════════════════════════════════════════ WHAT IT IS -->
    <section id="what" class="py-28 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20">
          <p class="text-forest-600 text-sm font-medium uppercase tracking-widest mb-4">The solution</p>
          <h2 class="font-display text-4xl md:text-5xl font-semibold text-forest-900 leading-tight max-w-3xl mx-auto">
            Your home. Your hardware. Your network. <em>Your rules.</em>
          </h2>
          <p class="mt-6 text-stone-500 max-w-2xl mx-auto leading-relaxed text-lg">
            Canopy turns your home computer into a personal server — your media, your household life,
            and a direct encrypted connection to the people you actually trust. No platform in the middle.
            No third party with their hands in your data. No terms of service that change without warning.
          </p>
        </div>

        <!-- The mesh / trust network -->
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-24">
          <div>
            <p class="text-forest-600 text-sm font-medium uppercase tracking-widest mb-4">A trust-based network</p>
            <h3 class="font-display text-3xl md:text-4xl font-semibold text-forest-900 leading-tight mb-7">
              Good things spread through people,<br /><em>not platforms.</em>
            </h3>
            <div class="space-y-5 text-stone-600 leading-relaxed text-[1.05rem]">
              <p>
                Damien discovers an album. Plays it on repeat all week and loves it so much that he shares a post. Jessica, whose Canopy is
                connected to Damien's, can see this, and can visit Damien's server and listen to it there — not because an algorithm
                served it to her, but because Damien genuinely loves it.
              </p>
              <p>
                She listens. Loves it. Her friend on another node sees it in her stream. And so it
                spreads — person to person, carried entirely by real enthusiasm, with no platform
                deciding who sees what and no feed engineered to keep you scrolling.
              </p>
              <p>
              No sponsored content. No monetisation. What's trending isn't what some platform wants to trend, it's what people are actually enjoying.
              </p>
              <p>
                This is how culture used to travel. Word of mouth, at the speed of trust.
                Six degrees of separation — if something is genuinely good, it doesn't need
                a platform to go viral. It just needs people willing to pass it on.
              </p>
            </div>
          </div>

          <!-- Mesh diagram -->
          <div class="bg-parchment/60 rounded-3xl p-8 border border-forest-100">
            <svg viewBox="0 0 480 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
              <line x1="130" y1="110" x2="240" y2="42" stroke="#8ec3a9" stroke-width="1.2" stroke-dasharray="5 4" opacity="0.5"/>
              <line x1="350" y1="110" x2="240" y2="42" stroke="#8ec3a9" stroke-width="1.2" stroke-dasharray="5 4" opacity="0.5"/>
              <line x1="130" y1="110" x2="350" y2="110" stroke="#2d6b52" stroke-width="2" opacity="0.7"/>
              <line x1="130" y1="110" x2="60" y2="220" stroke="#5fa385" stroke-width="1.5" opacity="0.6"/>
              <line x1="130" y1="110" x2="160" y2="235" stroke="#5fa385" stroke-width="1.5" opacity="0.6"/>
              <line x1="350" y1="110" x2="415" y2="218" stroke="#5fa385" stroke-width="1.5" opacity="0.6"/>
              <circle cx="240" cy="36" r="16" fill="#f0ebe0" stroke="#8ec3a9" stroke-width="1.5"/>
              <text x="240" y="40" text-anchor="middle" font-size="8" fill="#3c8769" font-family="Inter, system-ui" font-weight="500">coord</text>
              <circle cx="130" cy="110" r="28" fill="#19372c" stroke="#2d6b52" stroke-width="2"/>
              <text x="130" y="107" text-anchor="middle" font-size="9" fill="#8ec3a9" font-family="Inter, system-ui" font-weight="600">Jessica</text>
              <text x="130" y="119" text-anchor="middle" font-size="7" fill="#5fa385" font-family="Inter, system-ui">Atrium</text>
              <circle cx="350" cy="110" r="28" fill="#19372c" stroke="#2d6b52" stroke-width="2"/>
              <text x="350" y="107" text-anchor="middle" font-size="9" fill="#8ec3a9" font-family="Inter, system-ui" font-weight="600">Damien</text>
              <text x="350" y="119" text-anchor="middle" font-size="7" fill="#5fa385" font-family="Inter, system-ui">Atrium</text>
              <circle cx="60" cy="225" r="16" fill="#f0ebe0" stroke="#5fa385" stroke-width="1.5"/>
              <text x="60" y="229" text-anchor="middle" font-size="7.5" fill="#2d6b52" font-family="Inter, system-ui">Phone</text>
              <circle cx="165" cy="238" r="16" fill="#f0ebe0" stroke="#5fa385" stroke-width="1.5"/>
              <text x="165" y="242" text-anchor="middle" font-size="7.5" fill="#2d6b52" font-family="Inter, system-ui">Laptop</text>
              <circle cx="418" cy="222" r="16" fill="#f0ebe0" stroke="#5fa385" stroke-width="1.5"/>
              <text x="418" y="226" text-anchor="middle" font-size="7.5" fill="#2d6b52" font-family="Inter, system-ui">Phone</text>
              <text x="240" y="100" text-anchor="middle" font-size="8" fill="#5fa385" font-family="Inter, system-ui" opacity="0.9">wg-mesh</text>
              <text x="85" y="175" text-anchor="middle" font-size="7" fill="#8ec3a9" font-family="Inter, system-ui" opacity="0.8">wg-clients</text>
              <text x="395" y="175" text-anchor="middle" font-size="7" fill="#8ec3a9" font-family="Inter, system-ui" opacity="0.8">wg-clients</text>
            </svg>
            <div class="mt-4 flex flex-wrap gap-4 justify-center text-xs text-stone-500">
              <div class="flex items-center gap-2">
                <div class="w-6 h-0.5 bg-forest-600"></div>
                <span>Node mesh (WireGuard)</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-6 h-0.5 bg-forest-400"></div>
                <span>Your devices</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-5 border-t border-dashed border-forest-300"></div>
                <span>Coordination server</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Your media, everywhere -->
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-forest-900/15 border border-stone-200/80 aspect-[4/3]">
              <div class="bg-stone-200 px-4 py-2.5 flex items-center gap-2">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
                  <div class="w-3 h-3 rounded-full bg-amber-400/60"></div>
                  <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
                </div>
                <div class="flex-1 mx-4 bg-white/60 rounded text-[10px] text-stone-400 px-3 py-1 text-center">atrium.home.canopy</div>
              </div>
              <div class="flex h-full bg-gradient-to-br from-stone-50 to-amber-50/30">
                <div class="w-[28%] bg-stone-900 flex flex-col py-3 px-2">
                  <div class="px-3 pb-3 mb-2 border-b border-stone-800">
                    <div class="flex items-center gap-2">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-green-400">
                        <path d="M12 3L6 10h12L12 3z"/>
                        <path d="M12 7L4 15h16L12 7z"/>
                        <rect x="10" y="15" width="4" height="5" rx="0.5"/>
                      </svg>
                      <div>
                        <p class="text-stone-100 text-[9px] font-semibold leading-none">My Atrium</p>
                        <p class="text-stone-500 text-[8px] mt-0.5">Jessica</p>
                      </div>
                    </div>
                  </div>
                  <div class="space-y-0.5 px-1">
                    {['Dashboard', 'Services', 'Devices', 'Nodes', 'Catalogue'].map((item, i) => (
                      <div class={`px-2 py-1.5 rounded text-[9px] ${i === 1 ? 'bg-stone-800 text-green-400' : 'text-stone-500'}`}>
                        {item}
                      </div>
                    ))}
                  </div>
                  <div class="mt-auto px-3 pb-1">
                    <div class="flex items-center gap-1.5">
                      <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                      <span class="text-stone-500 text-[8px]">Connected · On the train</span>
                    </div>
                  </div>
                </div>
                <div class="flex-1 p-4">
                  <p class="text-stone-400 text-[9px] uppercase tracking-widest mb-3 font-medium">Running Services</p>
                  <div class="grid grid-cols-2 gap-2">
                    {[
                      { name: 'Jellyfin', desc: 'Films & TV', color: 'bg-violet-100 text-violet-700' },
                      { name: 'Navidrome', desc: 'Music', color: 'bg-blue-100 text-blue-700' },
                      { name: 'Nextcloud', desc: 'Files', color: 'bg-sky-100 text-sky-700' },
                      { name: 'PiHole', desc: 'DNS · Ad block', color: 'bg-red-100 text-red-600' },
                    ].map(s => (
                      <div class="bg-white/70 rounded-lg p-2.5 border border-stone-100">
                        <div class={`inline-block text-[8px] px-1.5 py-0.5 rounded font-medium mb-1 ${s.color}`}>{s.name}</div>
                        <p class="text-stone-500 text-[8px]">{s.desc}</p>
                        <div class="flex items-center gap-1 mt-1">
                          <div class="w-1 h-1 rounded-full bg-green-500"></div>
                          <span class="text-[7px] text-stone-400">running</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute -bottom-4 -right-4 bg-forest-700 text-cream text-xs px-4 py-2.5 rounded-xl shadow-lg font-medium">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
                Accessible from anywhere
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <p class="text-forest-600 text-sm font-medium uppercase tracking-widest mb-4">Own your media</p>
            <h3 class="font-display text-3xl md:text-4xl font-semibold text-forest-900 leading-tight mb-7">
              Your films. Your music. On your hardware. <em>Wherever you are.</em>
            </h3>
            <div class="space-y-5 text-stone-600 leading-relaxed text-[1.05rem]">
              <p>
                Jessica has her films on Jellyfin, her music on Navidrome, her files on Nextcloud —
                all running on her own hardware, on her own hard drive. No subscription. No licensing deal
                that can expire. No "this content isn't available in your region."
              </p>
              <p>
                When she leaves the house, her phone stays connected to her Atrium over an encrypted
                tunnel. She can stream her films on the train, check the household calendar, read messages
                left on the noticeboard. No VPN to configure. No port forwarding. Just connected.
              </p>
              <p class="text-forest-800 font-medium">
                No dependence on third-party companies. No one else's servers between you and your own stuff.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ FEATURES -->
    <section class="py-24 px-6 bg-parchment/50">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-forest-600 text-sm font-medium uppercase tracking-widest mb-4">What you get</p>
          <h2 class="font-display text-4xl md:text-5xl font-semibold text-forest-900 leading-tight">
            Everything your household needs
          </h2>
          <p class="mt-4 text-stone-500 max-w-xl mx-auto">
            Some features are built directly into the Atrium. Others run as containers you manage yourself. Both are yours, completely.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
          <div class="bg-cream rounded-3xl p-8 border border-forest-100">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-9 h-9 rounded-xl bg-forest-100 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-forest-700">
                  <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-forest-900 text-lg">The Atrium</h3>
                <p class="text-stone-400 text-xs">Everyday household tools</p>
              </div>
            </div>
            <div class="space-y-4">
              {[
                {
                  icon: `<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>`,
                  name: 'Household messaging',
                  desc: 'A shared noticeboard for the people you live with. Real-time, no app required. "Dinner\'s ready." "Don\'t forget the bins."',
                },
                {
                  icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
                  name: 'Shared calendar',
                  desc: 'Your household\'s schedule, visible to everyone at home — and shareable with friends on connected Atriums. No Google required.',
                },
                {
                  icon: `<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>`,
                  name: 'Chores',
                  desc: 'A shared task list. Assignees, due dates, recurring tasks. Surfaces on the dashboard so nothing gets missed.',
                },
                {
                  icon: `<path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>`,
                  name: 'Whatever you want',
                  desc: "It's open source! You can add whatever features you want to the server.",
                },
              ].map(f => (
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-forest-50 border border-forest-100 flex items-center justify-center mt-0.5">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="text-forest-600" set:html={f.icon}/>
                  </div>
                  <div>
                    <p class="font-medium text-forest-900 text-sm mb-1">{f.name}</p>
                    <p class="text-stone-500 text-sm leading-relaxed">{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-forest-900 rounded-3xl p-8 text-cream">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-9 h-9 rounded-xl bg-forest-800 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-forest-300">
                  <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
                  <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
                  <line x1="6" y1="6" x2="6.01" y2="6"/>
                  <line x1="6" y1="18" x2="6.01" y2="18"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-cream text-lg">Services</h3>
                <p class="text-forest-400 text-xs">Services you host, available to those on your network</p>
              </div>
            </div>
            <div class="space-y-4">
              {[
                {
                  name: 'Movie & TV streaming',
                  app: 'Jellyfin',
                  desc: 'Your ripped films and TV shows, streamable on any device. No licensing deals. No "this content isn\'t available in your region."',
                  tag: 'bg-violet-900/60 text-violet-300',
                },
                {
                  name: 'Music streaming',
                  app: 'Navidrome',
                  desc: 'Your own music library, streamable everywhere. And when connected to friends on the mesh, you can see what they\'ve been playing. The best recommendation engine is someone who actually knows you.',
                  tag: 'bg-blue-900/60 text-blue-300',
                },
                {
                  name: 'Files & documents',
                  app: 'Nextcloud',
                  desc: 'Your photos, documents, and backups on your own hardware. No model training on your files. No storage tiers.',
                  tag: 'bg-sky-900/60 text-sky-300',
                },
                {
                  name: 'Anything else',
                  app: 'Any container',
                  desc: 'Run any compatible container you like. The catalogue in the GUI makes discovery easy.',
                  tag: 'bg-stone-700 text-stone-300',
                },
              ].map(s => (
                <div class="flex gap-4">
                  <div class="flex-shrink-0 pt-1">
                    <span class={`text-[10px] font-medium px-2 py-0.5 rounded ${s.tag}`}>{s.app}</span>
                  </div>
                  <div>
                    <p class="font-medium text-cream text-sm mb-1">{s.name}</p>
                    <p class="text-forest-300/80 text-sm leading-relaxed">{s.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════ HOW IT WORKS -->
    <section id="how-it-works" class="py-24 px-6 bg-forest-900">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-forest-400 text-sm font-medium uppercase tracking-widest mb-4">Under the surface</p>
          <h2 class="font-display text-4xl md:text-5xl font-semibold text-cream leading-tight">
            Built right, from the ground up
          </h2>
          <p class="mt-4 text-forest-300/70 max-w-xl mx-auto">
            Every layer was chosen for a reason. Security, reproducibility, and openness aren't afterthoughts — they're the foundation.
          </p>
        </div>

        <div class="relative">
          <div class="absolute left-[calc(2rem+1px)] top-10 bottom-10 w-px bg-forest-700 hidden md:block"></div>
          <div class="space-y-10">
            {[
              {
                num: '1',
                name: 'NixOS',
                role: 'Operating System',
                desc: 'A fully declarative Linux distribution. All system configuration is expressed in .nix files — reproducible, auditable, and shareable. Your server is exactly what the config says it is. Always.',
                tag: 'Declarative · Reproducible',
              },
              {
                num: '2',
                name: 'Podman',
                role: 'Container Runtime',
                desc: 'Services run as isolated containers. Podman was chosen over Docker because it runs rootless — as its own unprivileged user — rather than as root. Each service is contained and self-sufficient.',
                tag: 'Rootless · Isolated',
              },
              {
                num: '3',
                name: 'Rust Daemon',
                role: 'System Layer',
                desc: 'A Rust process that handles all system-level operations: managing containers, configuring networking, executing system commands. It exposes a Unix socket. Nothing else touches the system.',
                tag: 'Root · Unix socket',
              },
              {
                num: '4',
                name: 'Bun + TypeScript',
                role: 'Management GUI',
                desc: 'A web interface served by Bun, running as an unprivileged user. Communicates with the Daemon via Unix socket. The code runs entirely on your machine — fully inspectable, fully customisable.',
                tag: 'Unprivileged · Customisable',
              },
            ].map((layer) => (
              <div class="relative flex gap-6 md:gap-10">
                <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-2xl bg-forest-800 border border-forest-700 flex items-center justify-center">
                  <span class="font-display font-bold text-forest-300 text-xl">{layer.num}</span>
                </div>
                <div class="flex-1 bg-forest-800/50 rounded-2xl p-6 border border-forest-700/50">
                  <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                    <div>
                      <h3 class="font-semibold text-cream text-lg">{layer.name}</h3>
                      <p class="text-forest-400 text-sm">{layer.role}</p>
                    </div>
                    <span class="text-[10px] bg-forest-900/60 text-forest-400 px-2.5 py-1 rounded-full font-mono border border-forest-700/50">{layer.tag}</span>
                  </div>
                  <p class="text-forest-300/80 leading-relaxed">{layer.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>

